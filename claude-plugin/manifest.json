{
  "manifest_version": "0.3",
  "name": "antinode-norma",
  "version": "0.1.0",
  "description": "BDD feature generator with INVEST quality gate. Transform user stories into validated Gherkin specs.",
  "author": {
    "name": "Antinode Labs",
    "email": "info@antinodelabs.com"
  },
  "license": "MIT",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "LLM_PROVIDER": "openrouter",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "LLM_URL": "${LLM_URL}",
        "LLM_MODEL": "openai/gpt-oss-120b:free",
        "LLM_BASE_URL": "https://openrouter.ai/api/v1",
        "LLM_TEMPERATURE": "0.2",
        "LLM_MAX_TOKENS": "1024",
        "JIRA_SERVER": "${JIRA_SERVER}",
        "JIRA_TOKEN": "${JIRA_TOKEN}",
        "CODEGEN_DEFAULT_FRAMEWORK": "${CODEGEN_DEFAULT_FRAMEWORK}",
        "CODEGEN_OUTPUT_DIR": "${CODEGEN_OUTPUT_DIR}",
        "CODEGEN_QUALITY_USE_PAGE_OBJECTS": "${CODEGEN_QUALITY_USE_PAGE_OBJECTS}",
        "CODEGEN_QUALITY_GENERATE_STEP_DEFS": "${CODEGEN_QUALITY_GENERATE_STEP_DEFS}",
        "CODEGEN_QUALITY_SELECTOR_STRATEGY": "${CODEGEN_QUALITY_SELECTOR_STRATEGY}",
        "CODEGEN_QUALITY_RUN_FORMATTER": "${CODEGEN_QUALITY_RUN_FORMATTER}",
        "CODEGEN_QUALITY_FORMATTER_TOOL": "${CODEGEN_QUALITY_FORMATTER_TOOL}"
      }
    }
  },
  "compatibility": {
    "claude_desktop": ">=0.1.0",
    "platforms": ["darwin", "win32"]
  }
}
