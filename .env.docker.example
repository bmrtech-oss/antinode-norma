# Local container seed configuration for antinode-norma

# Use the mock LLM provider to avoid external API calls during local development.
LLM_PROVIDER=mock

# Code generation defaults
CODEGEN_DEFAULT_FRAMEWORK=playwright
CODEGEN_FEATURE_DIR=features
CODEGEN_OUTPUT_DIR=generated_tests
CODEGEN_VERBOSE=false
CODEGEN_DRY_RUN=false

# Quality enhancement options
CODEGEN_QUALITY_USE_PAGE_OBJECTS=true
CODEGEN_QUALITY_GENERATE_STEP_DEFS=true
CODEGEN_QUALITY_SELECTOR_STRATEGY=data-testid
CODEGEN_QUALITY_ADD_EXPLICIT_WAITS=true
CODEGEN_QUALITY_ENABLE_SCENARIO_OUTLINES=true
CODEGEN_QUALITY_RUN_FORMATTER=false
CODEGEN_QUALITY_RUN_LINTER=false
CODEGEN_QUALITY_PAGE_OBJECT_DIR=pages
CODEGEN_QUALITY_STEP_DEF_DIR=steps
CODEGEN_QUALITY_USE_LLM_MAPPING=false
CODEGEN_QUALITY_WAIT_TIMEOUT=10000
CODEGEN_QUALITY_RETRY_COUNT=1
