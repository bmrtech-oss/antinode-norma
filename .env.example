# LLM Configuration
# Supported providers: anthropic, openai, openrouter, local, mock
# For local container development and sandbox testing, you can copy `.env.docker.example` to `.env`.
# That file uses `LLM_PROVIDER=mock` and is designed to run the full app flow without external API keys.
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-...

# OpenAI
OPENAI_API_KEY=sk-...

# OpenRouter (uses OpenAI SDK)
OPENROUTER_API_KEY=sk-or-...
# Optional: override model and base URL
# LLM_MODEL=openai/gpt-oss-120b:free
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Common LLM settings
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# JIRA (optional)
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_TOKEN=your_personal_access_token

# Agent configuration
AGENT_MAX_ITERATIONS=10
AGENT_HUMAN_IN_THE_LOOP=false

# ============================================================
# Code Generator (antinode_norma.codegen) settings
# ============================================================

# Core settings
CODEGEN_DEFAULT_FRAMEWORK=playwright        # playwright, cypress, selenium
CODEGEN_FEATURE_DIR=features
CODEGEN_OUTPUT_DIR=generated_tests
CODEGEN_VERBOSE=false
CODEGEN_DRY_RUN=false

# Quality enhancements (optional)
CODEGEN_QUALITY_USE_PAGE_OBJECTS=true
CODEGEN_QUALITY_GENERATE_STEP_DEFS=true
CODEGEN_QUALITY_SELECTOR_STRATEGY=data-testid
CODEGEN_QUALITY_ADD_EXPLICIT_WAITS=true
CODEGEN_QUALITY_ENABLE_SCENARIO_OUTLINES=true
CODEGEN_QUALITY_RUN_FORMATTER=true
CODEGEN_QUALITY_FORMATTER_TOOL=prettier     # prettier, black, or auto
CODEGEN_QUALITY_RUN_LINTER=false
CODEGEN_QUALITY_LINTER_TOOL=null
CODEGEN_QUALITY_PAGE_OBJECT_DIR=pages
CODEGEN_QUALITY_STEP_DEF_DIR=steps
CODEGEN_QUALITY_USE_LLM_MAPPING=true
CODEGEN_QUALITY_LLM_MAPPING_CACHE_SIZE=1000
CODEGEN_QUALITY_LLM_MAPPING_TIMEOUT=5
CODEGEN_QUALITY_WAIT_TIMEOUT=10000
CODEGEN_QUALITY_RETRY_COUNT=2
